{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "declarationMap": false,
    "emitDeclarationOnly": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmitOnError": true,
    "outDir": "./types",
    "removeComments": false,
    "paths": {
      "@sl-utils/map": [
        "./src/index.ts"
      ],
      "src/*": [
        "./src/*"
      ]
    },
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts",
    "types/assets.d.ts"
  ],
  "exclude": [
    "demo",
    "node_modules",
    "build",
    "dist",
    "types/generated"
  ]
}
